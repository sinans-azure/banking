DB_HOST=your-postgresql-server.postgres.database.azure.com
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=banking_db
DB_PORT=5432

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account;AccountKey=your_key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=documents

SESSION_SECRET=replace_with_a_long_random_value
OCR_FUNCTION_URL=https://your-function-app.azurewebsites.net/api/your-http-trigger
OCR_FUNCTION_KEY=optional_http_trigger_function_key
OCR_WEBHOOK_SECRET=optional_shared_secret_for_blob_trigger_callbacks

PORT=8080
